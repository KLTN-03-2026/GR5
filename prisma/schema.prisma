  bien_the_san_pham bien_the_san_pham? @relation(fields: [ma_bien_the], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chi_tiet_gio_hang_ibfk_2")

  @@index([ma_bien_the], map: "ma_bien_the")
