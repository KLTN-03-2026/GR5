  @@index([ma_kien_hang], map: "ma_kien_hang")
  @@index([ma_phieu_kiem_ke], map: "ma_phieu_kiem_ke")
  @@index([ma_phieu_nhap], map: "ma_phieu_nhap")
  @@index([ma_phieu_xuat], map: "ma_phieu_xuat")
