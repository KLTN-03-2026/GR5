generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model anh_danh_gia {
  id                Int                @id @default(autoincrement())
  ma_danh_gia       Int?
  duong_dan_anh     String             @db.VarChar(255)
  danh_gia_san_pham danh_gia_san_pham? @relation(fields: [ma_danh_gia], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "anh_danh_gia_ibfk_1")

  @@index([ma_danh_gia], map: "ma_danh_gia")
}

model anh_san_pham {
  id            Int       @id @default(autoincrement())
  ma_san_pham   Int?
  duong_dan_anh String    @db.VarChar(255)
  la_anh_chinh  Boolean?  @default(false)
  san_pham      san_pham? @relation(fields: [ma_san_pham], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "anh_san_pham_ibfk_1")

  @@index([ma_san_pham], map: "ma_san_pham")
}

model banner_quang_cao {
  id             Int      @id @default(autoincrement())
  tieu_de        String?  @db.VarChar(255)
  duong_dan_anh  String?  @db.VarChar(255)
  thu_tu_sap_xep Int?     @default(0)
  dang_hoat_dong Boolean? @default(true)
}

model bien_the_san_pham {
  id                  Int                   @id @default(autoincrement())
  ma_san_pham         Int?
  ma_sku              String?               @unique(map: "ma_sku") @db.VarChar(50)
  ten_bien_the        String?               @db.VarChar(100)
  don_vi_tinh         String?               @db.VarChar(20)
  gia_ban             Decimal               @db.Decimal(15, 2)
  gia_goc             Decimal?              @db.Decimal(15, 2)
  san_pham            san_pham?             @relation(fields: [ma_san_pham], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bien_the_san_pham_ibfk_1")
  chi_tiet_doi_tra    chi_tiet_doi_tra[]
  chi_tiet_don_hang   chi_tiet_don_hang[]
  chi_tiet_gio_hang   chi_tiet_gio_hang[]
  chi_tiet_phieu_nhap chi_tiet_phieu_nhap[]
  chi_tiet_phieu_xuat chi_tiet_phieu_xuat[]
  lo_hang             lo_hang[]
  ma_giam_gia         ma_giam_gia[]

  @@index([ma_san_pham], map: "ma_san_pham")
}

model ca_lam_viec {
  id                Int                 @id @default(autoincrement())
  ten_ca            String              @db.VarChar(50)
  gio_bat_dau       DateTime?           @db.Time(0)
  gio_ket_thuc      DateTime?           @db.Time(0)
  lich_phan_cong_ca lich_phan_cong_ca[]
  lich_su_cham_cong lich_su_cham_cong[]
}

model canh_bao_lo_hang {
  id                Int       @id @default(autoincrement())
  ma_lo_hang        Int
  loai_canh_bao     String    @db.VarChar(50)
  so_ngay_con       Int?
  da_xu_ly          Boolean   @default(false)
  ngay_tao          DateTime  @default(now())
  ngay_xu_ly        DateTime?
  phuong_thuc_xu_ly String?   @db.VarChar(50)
  nguoi_xu_ly_id    Int?
  ghi_chu_xu_ly     String?   @db.Text
  ma_phieu_xu_ly    Int?
