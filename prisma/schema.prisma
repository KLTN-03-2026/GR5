  danh_muc           danh_muc?            @relation(fields: [ma_danh_muc], references: [id], onUpdate: NoAction, map: "san_pham_ibfk_1")
  the_san_pham       the_san_pham[]
  ncc_san_pham       ncc_san_pham[]

  @@index([ma_danh_muc], map: "ma_danh_muc")
}

model the_san_pham {
