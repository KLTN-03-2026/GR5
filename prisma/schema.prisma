}

model chi_tiet_luan_chuyen_kho {
  id                 Int                @id @default(autoincrement())
  ma_phieu_nhap      Int?
  ma_phieu_xuat      Int?
  ma_phieu_kiem_ke   Int?
  ma_kien_hang       Int
